//schema.prisma.js

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(uuid())
  name       String?
  email      String   @unique
  password   String?  // optional (Google users won't have it)
  googleId   String?  @unique 
  avatar     String?  
  createdAt  DateTime @default(now())
}
